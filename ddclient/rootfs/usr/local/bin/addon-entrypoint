#!/bin/sh
set -eu

OPTIONS_PATH=${ADDON_OPTIONS_PATH:-/data/options.json}
CONFIG_DIR=${ADDON_CONFIG_DIR:-/config}
# ADDON_DDCLIENT_BIN is the ddclient binary; tests override it with a recorder.
ADDON_DDCLIENT_BIN=${ADDON_DDCLIENT_BIN:-ddclient}
CONF_FILE="${CONFIG_DIR}/ddclient.conf"
CACHE_FILE="${CONFIG_DIR}/ddclient.cache"

log() {
    printf '%s\n' "[ddclient-addon] $*" >&2
}

fail() {
    log "Error: $*"
    exit 1
}

[ -r "$OPTIONS_PATH" ] || fail "Options file is not readable: $OPTIONS_PATH"
command -v jq >/dev/null 2>&1 || fail "jq is required"

# Validate options. The config is written verbatim to ddclient.conf, so reject
# an empty value and control characters other than tab, newline, and carriage
# return that could corrupt the file or hide injected directives.
if ! jq -e '
    type == "object"
    and (.config | type == "string" and length > 0
        and ((explode
            | map(select((. < 32 and . != 9 and . != 10 and . != 13) or . == 127))
            | length) == 0))
' "$OPTIONS_PATH" >/dev/null 2>&1; then
    fail "Invalid options: config must be a non-empty string without control characters"
fi

umask 077
mkdir -p "$CONFIG_DIR"

# Write ddclient.conf privately; it carries provider credentials, so the value
# is never logged.
temporary=$(mktemp "${CONFIG_DIR}/.ddclient.conf.XXXXXX") ||
    fail "Cannot create configuration temporary file"
if ! jq -r '.config' "$OPTIONS_PATH" >"$temporary"; then
    rm -f "$temporary"
    fail "Cannot write ddclient configuration"
fi
chmod 0600 "$temporary" || {
    rm -f "$temporary"
    fail "Cannot secure ddclient configuration"
}
mv -f "$temporary" "$CONF_FILE" || {
    rm -f "$temporary"
    fail "Cannot install ddclient configuration"
}

# ddclient only loops in the foreground when a daemon interval is set. Without
# one it runs a single update and exits, which restarts the add-on container in
# a loop, so fall back to a sane interval when the configuration omits daemon.
daemon_flag=""
if ! grep -Eq '^[[:space:]]*daemon[[:space:]]*=' "$CONF_FILE"; then
    daemon_flag="-daemon=300"
    log "No daemon interval in configuration; defaulting to 300s"
fi

log "Configuration written to ${CONF_FILE}; starting ddclient"
# Run in the foreground so ddclient stays PID 1 and honors the daemon interval.
# The cache persists under the writable config mapping.
# shellcheck disable=SC2086
exec "$ADDON_DDCLIENT_BIN" -foreground $daemon_flag \
    -file "$CONF_FILE" \
    -cache "$CACHE_FILE" \
    "$@"
